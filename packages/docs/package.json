{
	"name": "fork-docs",
	"version": "0.0.1",
	"description": "Documentation site for fork.",
	"private": true,
	"scripts": {
		"dev": "astro dev",
		"build": "astro build && bunx pagefind --site dist --output-subdir projects/fork/_pagefind",
		"preview": "wrangler dev",
		"deploy": "astro build && bunx pagefind --site dist --output-subdir projects/fork/_pagefind && wrangler deploy"
	},
	"dependencies": {
		"@astrojs/cloudflare": "^12.0.0",
		"@astrojs/react": "^4.0.0",
		"@astrojs/sitemap": "^3.7.1",
		"@luciodale/docs-ui-kit": "^0.3.34",
		"@tailwindcss/vite": "^4.1.18",
		"astro": "^5.0.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"tailwindcss": "^4.1.18"
	},
	"devDependencies": {
		"wrangler": "^4.0.0"
	}
}
